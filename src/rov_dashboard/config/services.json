{
  "services": [
    {
      "id": "full_simulation_stack",
      "node_name": "/sim_launch",
      "aliases": [
        "simulation",
        "gazebo",
        "bridge",
        "my_robot_sim"
      ],
      "name": "Full Simulation Stack",
      "description": "Runs ros2 launch my_robot_sim sim.launch.py. This starts Gazebo, ros_gz_bridge parameter_bridge, ros_gz_image image_bridge, thruster_controller, and depth_hold_node.",
      "type": "launch",
      "status": "stopped",
      "start_command": "ros2 launch my_robot_sim sim.launch.py",
      "stop_method": "managed_shutdown",
      "logs": {
        "source": "full_simulation_stack",
        "max_lines": 200
      }
    },
    {
      "id": "thruster_controller",
      "node_name": "/thruster_controller",
      "aliases": [
        "robot_controller",
        "my_robot_sim.control"
      ],
      "name": "Thruster Controller",
      "description": "Standalone my_robot_sim robot_controller executable. Normally already started by full_simulation_stack.",
      "type": "ros_node",
      "status": "stopped",
      "start_command": "ros2 run my_robot_sim robot_controller",
      "stop_method": "managed_shutdown",
      "logs": {
        "source": "/thruster_controller",
        "max_lines": 200
      }
    },
    {
      "id": "depth_hold_node",
      "node_name": "/depth_hold_node",
      "aliases": [
        "depth_hold",
        "my_robot_sim.depth_hold_node"
      ],
      "name": "Depth Hold Node",
      "description": "Standalone pulse-based ballast depth controller. Normally already started by full_simulation_stack.",
      "type": "ros_node",
      "status": "stopped",
      "start_command": "ros2 run my_robot_sim depth_hold_node",
      "stop_method": "managed_shutdown",
      "logs": {
        "source": "/depth_hold_node",
        "max_lines": 200
      }
    },
    {
      "id": "rov_api_server",
      "node_name": "/rov_api_server",
      "aliases": [
        "server",
        "flask_api",
        "camera_server"
      ],
      "name": "ROV Flask API + Camera Server",
      "description": "Runs my_robot_sim.server on port 5000. Publishes /rov/move_cmd and serves /camera.jpg, /camera.mjpg, and /health.",
      "type": "api",
      "status": "stopped",
      "start_command": "ros2 run my_robot_sim server",
      "stop_method": "managed_shutdown",
      "logs": {
        "source": "/rov_api_server",
        "max_lines": 200
      }
    },
    {
      "id": "keyboard_controller",
      "node_name": "/rov_keyboard_controller",
      "aliases": [
        "keyboard",
        "operator_keyboard"
      ],
      "name": "Keyboard Controller",
      "description": "Interactive terminal keyboard controller. Best run manually in a terminal because it reads raw keyboard input from stdin.",
      "type": "operator_tool",
      "status": "stopped",
      "start_command": "ros2 run my_robot_sim keyboard_controller",
      "stop_method": "managed_shutdown",
      "logs": {
        "source": "/rov_keyboard_controller",
        "max_lines": 200
      }
    },
    {
      "id": "dashboard_backend",
      "node_name": "/dashboard_ros_interface",
      "aliases": [
        "rov_dashboard",
        "fastapi_dashboard"
      ],
      "name": "Dashboard Backend",
      "description": "FastAPI dashboard backend on port 8000. It serves the web UI and owns the dashboard_ros_interface ROS node.",
      "type": "web_backend",
      "status": "running",
      "start_command": "ros2 run rov_dashboard dashboard_backend",
      "stop_method": "managed_shutdown",
      "logs": {
        "source": "/dashboard_ros_interface",
        "max_lines": 200
      }
    }
  ]
}