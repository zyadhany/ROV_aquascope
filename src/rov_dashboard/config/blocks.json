{
  "blocks": [
    {
      "id": "/hardware/microcontroller",
      "name": "Microcontroller",
      "type": "interface",
      "category": "Hardware",
      "description": "Main microcontroller connected to the real ROV hardware. Receives actuator commands from the MCU Gateway over serial and sends sensor data back."
    },
    {
      "id": "/hardware/actuators/left_thruster",
      "name": "Left Thruster",
      "type": "thruster",
      "category": "Actuators",
      "description": "Left physical thruster controlled by the microcontroller."
    },
    {
      "id": "/hardware/actuators/right_thruster",
      "name": "Right Thruster",
      "type": "thruster",
      "category": "Actuators",
      "description": "Right physical thruster controlled by the microcontroller."
    },
    {
      "id": "/hardware/actuators/pump",
      "name": "Pump",
      "type": "pump",
      "category": "Actuators",
      "description": "Pump actuator controlled by the microcontroller. Used by the depth controller for vertical/depth control."
    },
    {
      "id": "/hardware/actuators/light",
      "name": "Light",
      "type": "light",
      "category": "Actuators",
      "description": "ROV light controlled by the microcontroller."
    },
    {
      "id": "/hardware/sensors/camera",
      "name": "Camera",
      "type": "camera",
      "category": "Sensors",
      "description": "Camera hardware. It is handled by the Camera Streamer node, not through the microcontroller serial connection."
    },
    {
      "id": "/hardware/sensors/imu",
      "name": "IMU",
      "type": "sensor",
      "category": "Sensors",
      "description": "IMU sensor connected to the microcontroller."
    },
    {
      "id": "/hardware/sensors/pressure_sensor",
      "name": "Pressure Sensor",
      "type": "sensor",
      "category": "Sensors",
      "description": "Pressure sensor connected to the microcontroller. Used to produce pressure data and current depth."
    },
    {
      "id": "/nodes/mcu_gateway",
      "name": "MCU Gateway",
      "type": "node",
      "category": "Nodes",
      "description": "Backend/ROS node that communicates with the microcontroller over serial. It receives ROS command topics and publishes processed sensor data.",
      "ros_node": "/mcu_gateway",
      "logs": {
        "source": "/mcu_gateway",
        "level": "info",
        "max_lines": 100
      }
    },
    {
      "id": "/nodes/camera_streamer",
      "name": "Camera Streamer",
      "type": "node",
      "category": "Nodes",
      "description": "Node that reads the camera stream and publishes camera frames/images without loading the microcontroller serial connection.",
      "ros_node": "/camera_streamer",
      "logs": {
        "source": "/camera_streamer",
        "level": "info",
        "max_lines": 100
      }
    },
    {
      "id": "/topics/camera/image",
      "name": "Camera Image",
      "type": "topic",
      "category": "Topics",
      "description": "Published camera image stream from the Camera Streamer node.",
      "ros_topic": "/rov/camera/image",
      "message_type": "sensor_msgs/Image",
      "show": {
        "publishers": true,
        "subscribers": true,
        "latest_message": false,
        "frequency": true
      }
    },
    {
      "id": "/topics/pressure/data",
      "name": "Pressure Data",
      "type": "topic",
      "category": "Topics",
      "description": "Raw or processed pressure data published by the MCU Gateway.",
      "ros_topic": "/rov/pressure/data",
      "message_type": "std_msgs/Float64",
      "show": {
        "publishers": true,
        "subscribers": true,
        "latest_message": true,
        "frequency": true
      }
    },
    {
      "id": "/topics/depth/current",
      "name": "Current Depth",
      "type": "topic",
      "category": "Topics",
      "description": "Current calculated depth published by the MCU Gateway.",
      "ros_topic": "/rov/depth/current",
      "message_type": "std_msgs/Float64",
      "show": {
        "publishers": true,
        "subscribers": true,
        "latest_message": true,
        "frequency": true
      }
    },
    {
      "id": "/topics/depth/target",
      "name": "Target Depth",
      "type": "topic",
      "category": "Topics",
      "description": "Target depth published by the ROV Controller and consumed by the Depth Controller.",
      "ros_topic": "/rov/depth/target",
      "message_type": "std_msgs/Float64",
      "show": {
        "publishers": true,
        "subscribers": true,
        "latest_message": true,
        "frequency": true
      }
    },
    {
      "id": "/topics/depth/error",
      "name": "Depth Error",
      "type": "topic",
      "category": "Topics",
      "description": "Depth error published by the Depth Controller.",
      "ros_topic": "/rov/depth/error",
      "message_type": "std_msgs/Float64",
      "show": {
        "publishers": true,
        "subscribers": true,
        "latest_message": true,
        "frequency": true
      }
    },
    {
      "id": "/topics/cmd/left_thruster",
      "name": "Left Thruster Command",
      "type": "topic",
      "category": "Command Topics",
      "description": "Left thruster command sent to the MCU Gateway.",
      "ros_topic": "/rov/mcu/cmd/left_thruster",
      "message_type": "std_msgs/Float64",
      "show": {
        "publishers": true,
        "subscribers": true,
        "latest_message": true,
        "frequency": true
      }
    },
    {
      "id": "/topics/cmd/right_thruster",
      "name": "Right Thruster Command",
      "type": "topic",
      "category": "Command Topics",
      "description": "Right thruster command sent to the MCU Gateway.",
      "ros_topic": "/rov/mcu/cmd/right_thruster",
      "message_type": "std_msgs/Float64",
      "show": {
        "publishers": true,
        "subscribers": true,
        "latest_message": true,
        "frequency": true
      }
    },
    {
      "id": "/topics/cmd/pump",
      "name": "Pump Command",
      "type": "topic",
      "category": "Command Topics",
      "description": "Pump command sent to the MCU Gateway.",
      "ros_topic": "/rov/mcu/cmd/pump",
      "message_type": "std_msgs/Int32",
      "show": {
        "publishers": true,
        "subscribers": true,
        "latest_message": true,
        "frequency": true
      }
    },
    {
      "id": "/topics/cmd/light",
      "name": "Light Command",
      "type": "topic",
      "category": "Command Topics",
      "description": "Light command sent to the MCU Gateway.",
      "ros_topic": "/rov/mcu/cmd/light",
      "message_type": "std_msgs/Bool",
      "show": {
        "publishers": true,
        "subscribers": true,
        "latest_message": true,
        "frequency": true
      }
    },
    {
      "id": "/nodes/depth_controller",
      "name": "Depth Controller",
      "type": "node",
      "category": "Control Nodes",
      "description": "Controller node that subscribes to current depth and target depth, publishes depth error, and commands the pump.",
      "ros_node": "/depth_controller",
      "logs": {
        "source": "/depth_controller",
        "level": "info",
        "max_lines": 100
      }
    },
    {
      "id": "/nodes/rov_controller",
      "name": "ROV Controller",
      "type": "node",
      "category": "Control Nodes",
      "description": "Main control node that converts high-level control commands into actuator commands and target depth.",
      "ros_node": "/rov_controller",
      "logs": {
        "source": "/rov_controller",
        "level": "info",
        "max_lines": 100
      }
    },
    {
      "id": "/nodes/keyboard_controller",
      "name": "Keyboard Controller",
      "type": "node",
      "category": "Input Controllers",
      "description": "Keyboard input node that publishes high-level control commands.",
      "ros_node": "/keyboard_controller",
      "logs": {
        "source": "/keyboard_controller",
        "level": "info",
        "max_lines": 100
      }
    },
    {
      "id": "/topics/control/command",
      "name": "Control Command",
      "type": "topic",
      "category": "Command Topics",
      "description": "High-level command topic used by input controllers and consumed by the ROV Controller.",
      "ros_topic": "/rov/controller/cmd",
      "message_type": "std_msgs/String",
      "show": {
        "publishers": true,
        "subscribers": true,
        "latest_message": true,
        "frequency": true
      }
    },
    {
      "id": "/nodes/mobile_app_controller",
      "name": "Mobile App Controller",
      "type": "node",
      "category": "Input Controllers",
      "description": "Mobile app input node that publishes high-level control commands.",
      "ros_node": "/mobile_app_controller",
      "logs": {
        "source": "/mobile_app_controller",
        "level": "info",
        "max_lines": 100
      }
    }
  ],
  "connections": [
